-# Pydantic 모델 정의
-class Message(BaseModel):
-    role: str = Field(..., description="발화 주체: 'user' 또는 'assistant'")
-    content: str = Field(..., description="발화 내용")
-
-
-class ChatRequest(BaseModel):
-    query: str = Field(..., description="현재 사용자 입력")
-    messages: Optional[List[Message]] = Field(default=[], description="이전 대화 메시지 목록")
-    summary: Optional[str] = Field(default=None, description="압축된 이전 대화 요약")
-    user_id: Optional[int] = Field(default=None, description="대상자 ID (RAG 컨텍스트 조회용)")
-
-
-class ChatResponse(BaseModel):
-    answer: str = Field(..., description="AI 응답 텍스트")
-    summary: Optional[str] = Field(default=None, description="대화 요약본 (임계치 초과 시 요약 갱신, 그 외엔 null)")
-
-
-class SummaryRequest(BaseModel):
-    messages: List[Message] = Field(..., description="분석할 전체 대화 메시지 목록")
-
-
-class SummaryResponse(BaseModel):
-    places: List[str] = Field(..., description="대화에서 언급된 장소 목록")
-    people: List[str] = Field(..., description="대화에서 언급된 인물 이름 목록")
-    next_topics: List[str] = Field(..., description="다음 대화에서 꺼낼 수 있는 추천 주제 3가지")
-
-
-class TTSRequest(BaseModel):
