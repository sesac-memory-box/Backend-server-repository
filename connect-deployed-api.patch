-# API 엔드포인트 구현
-
-@app.post("/chat/", response_model=ChatResponse)
-async def chat(request: ChatRequest):
-    """
-    사용자 쿼리에 대해 RAG 기반 AI 응답을 생성합니다.
-    대화 내역의 개수가 임계치 이상 도달 시 자동으로 요약을 생성하여 응답에 포함시킵니다.
-    """
-    # RAG 컨텍스트 조회
-    rag_context = retrieve_rag_context(request.user_id, request.query)
-    
-    # 시스템 프롬프트 작성
-    system_prompt = f"""당신은 치매 어르신을 위한 친절한 회상 대화 전문 상담사입니다.
-    
-{rag_context}
-
-대화 원칙:
-1. 어르신의 과거 소중한 경험을 떠올릴 수 있도록 오감(냄새, 소리, 느낌 등)을 자극하는 열린 질문을 하세요.
-2. 어르신의 이야기를 경청하고 적극적으로 공감하며 위로와 기쁨을 선사하세요.
-3. 길고 복잡한 문장은 이해하기 힘들 수 있으니, 항상 2~3문장 이내로 쉽고 명확하게 한국어로 다정하게 대답하세요.
-4. 어르신의 이름이나 취향(좋아하는 음식, 장소 등)을 자연스럽게 대화에 녹여내세요.
-"""
-    
-    # OpenAI 메시지 목록 구성
-    messages_payload = [{"role": "system", "content": system_prompt}]
-    
-    # 압축된 요약본(summary)이 전달된 경우, 요약본을 먼저 역사적 사실/대화 맥락으로 제공
-    if request.summary:
-        messages_payload.append({
-            "role": "system", 
-            "content": f"이전 대화 요약 내용 (참고용): {request.summary}"
-        })
-        
-    # 클라이언트가 전달한 최근 메시지들 추가
-    for msg in request.messages:
-        role = "user" if msg.role == "user" else "assistant"
-        messages_payload.append({"role": role, "content": msg.content})
-        
-    # 현재 쿼리 추가
-    messages_payload.append({"role": "user", "content": request.query})
-    
-    # 1. AI 응답 생성
-    answer = ""
-    if client:
-        try:
-            chat_completion = client.chat.completions.create(
-                model="gpt-4o",  # gpt-4o가 성능 및 한글 표현이 우수함
-                messages=messages_payload,
-                max_tokens=250,
-                temperature=0.7
-            )
-            answer = chat_completion.choices[0].message.content.strip()
-        except Exception as e:
-            print(f"[OpenAI Chat Error] {e}")
-            raise HTTPException(status_code=500, detail=f"OpenAI API 호출 중 오류가 발생했습니다: {str(e)}")
-    else:
-        # 모의(Mock) 응답 생성
-        user_name = "어르신"
-        if request.user_id:
-            user = UserManager.get_user_by_id(request.user_id)
-            if user:
-                user_name = user['name']
-        answer = f"어머나, {user_name}님! 말씀해 주신 '{request.query}' 이야기를 들으니 저도 마음이 참 뭉클하고 따뜻해지네요. 그때 참 행복하셨겠어요. 또 재미있는 이야기가 있다면 더 들려주세요."
-
-    # 2. 임계치 도달 여부 검사 및 요약(Summary) 생성
-    new_summary = None
-    # 전달받은 이전 메시지의 개수 검사
-    if len(request.messages) >= SUMMARY_THRESHOLD:
-        # 요약 생성 프롬프트
-        summary_prompt = f"""당신은 상담사와 치매 어르신 간의 대화 요약 전문가입니다.
-다음 대화 기록과 이전 요약 내용을 바탕으로, 지금까지의 핵심 대화 주제 및 언급된 주요 추억 정보를 하나로 통합하여 1~2문장의 아주 다정하고 간결한 한국어 문단으로 요약해주세요.
-
-이전 요약 내용:
-{request.summary or '없음'}
-
-최근 대화 내용:
-"""
-        for msg in request.messages:
-            summary_prompt += f"{'어르신' if msg.role == 'user' else '상담사'}: {msg.content}\n"
-            
-        summary_prompt += f"어르신: {request.query}\n"
-        summary_prompt += f"상담사: {answer}\n"
-        summary_prompt += "\n새 요약본 작성:"
-        
-        if client:
-            try:
-                summary_completion = client.chat.completions.create(
-                    model="gpt-4o",
-                    messages=[
-                        {"role": "system", "content": "대화 요약을 생성하는 어시스턴트입니다."},
-                        {"role": "user", "content": summary_prompt}
-                    ],
-                    max_tokens=150,
-                    temperature=0.5
-                )
-                new_summary = summary_completion.choices[0].message.content.strip()
-                print(f"[API 요약 생성 완료] {new_summary}")
-            except Exception as e:
-                print(f"[OpenAI Summary Error] {e}")
-                new_summary = "[대화 요약 생성에 실패했습니다]"
-        else:
-            # Mock 요약
-            new_summary = f"[요약] 어르신이 말씀해주신 '{request.query}' 관련 과거 추억과 경험에 대하여 깊은 이야기를 나누고 공감했습니다."
-
-    return ChatResponse(answer=answer, summary=new_summary)
-
