-@app.post("/chat/summary", response_model=SummaryResponse)
-async def chat_summary(request: SummaryRequest):
-    """
-    대화가 완전히 종료되었을 때, 전체 대화 내용을 분석하여 장소, 인물, 다음 대화 맞춤 추천 주제를 추출해 줍니다.
-    """
-    if not request.messages:
-        raise HTTPException(status_code=400, detail="요약할 메시지 내역이 비어 있습니다.")
-        
-    conversation_text = ""
-    for msg in request.messages:
-        speaker = "어르신" if msg.role == "user" else "상담사"
-        conversation_text += f"{speaker}: {msg.content}\n"
-        
-    prompt = f"""당신은 노인 대화 분석 전문가입니다. 아래 대화 내역을 분석하여 대화 중 어르신이 언급한 장소와 인물 이름을 추출하고, 다음 대화에서 꺼내기 좋은 개인 맞춤형 추천 주제 3가지를 만들어 JSON 포맷으로 출력해 주세요.
-
-대화 내역:
-{conversation_text}
-
-반드시 다음 JSON 형식 스키마를 엄격히 지켜 응답하십시오 (JSON 외의 텍스트 설명이나 마크다운 백틱은 절대 포함하지 마십시오):
-{{
-  "places": ["장소 1", "장소 2", ...],
-  "people": ["인물 이름 1", "인물 이름 2", ...],
-  "next_topics": [
-    "추천 대화 주제 1",
-    "추천 대화 주제 2",
-    "추천 대화 주제 3"
-  ]
-}}
-"""
-    
-    if client:
-        try:
-            completion = client.chat.completions.create(
-                model="gpt-4o",
-                messages=[
-                    {"role": "system", "content": "너는 JSON 형식으로만 결과물을 반환하는 분석 어시스턴트야. 항상 올바른 JSON 파싱이 가능하도록 반환해."},
-                    {"role": "user", "content": prompt}
-                ],
-                response_format={"type": "json_object"} if hasattr(client, "chat") else None,
-                temperature=0.4
-            )
-            raw_content = completion.choices[0].message.content.strip()
-            
-            # JSON 파싱 시도
-            try:
-                data = json.loads(raw_content)
-                return SummaryResponse(
-                    places=data.get("places", []),
-                    people=data.get("people", []),
-                    next_topics=data.get("next_topics", [])[:3]
-                )
-            except json.JSONDecodeError:
-                # JSON 파싱 실패 시 수동 처리
-                print(f"[JSON 파싱 실패] Raw Content: {raw_content}")
-                raise HTTPException(status_code=500, detail="AI가 반환한 결과를 파싱하는 데 실패했습니다.")
-        except Exception as e:
-            print(f"[OpenAI Chat Summary Error] {e}")
-            raise HTTPException(status_code=500, detail=f"OpenAI 요약 분석 중 오류 발생: {str(e)}")
-    else:
-        # Mock 데이터 반환
-        return SummaryResponse(
-            places=["공원", "시장"],
-            people=["민준", "동네 친구"],
-            next_topics=[
-                "시장에 얽힌 옛 추억",
-                "민준이와의 행복했던 순간",
-                "어릴 적 자주 놀던 골목길"
-            ]
-        )
-
