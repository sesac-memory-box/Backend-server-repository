-# Helper: RAG 컨텍스트 구축 및 검색
-def retrieve_rag_context(user_id: Optional[int], query: str) -> str:
-    """
-    대상자 프로필 정보(RAG) 및 관련 회상 소재 정보를 가져와서 컨텍스트 문자열로 만듭니다.
-    """
-    context = ""
-    
-    # 1. 대상자 프로필 검색
-    user_info = None
-    if user_id:
-        user_info = UserManager.get_user_by_id(user_id)
-    else:
-        # user_id가 없으면 DB에 등록된 첫 번째 사용자를 기본값으로 사용
-        users = UserManager.get_all_users()
-        if users:
-            user_info = users[0]
-            
-    if user_info:
-        context += f"대화 상대(어르신) 정보:\n"
-        context += f"- 이름: {user_info.get('name', '어르신')}\n"
-        if user_info.get('birth_year'):
-            context += f"- 출생연도: {user_info.get('birth_year')}년\n"
-        if user_info.get('gender'):
-            context += f"- 성별: {user_info.get('gender')}\n"
-        if user_info.get('past_job'):
-            context += f"- 과거 직업: {user_info.get('past_job')}\n"
-        if user_info.get('residence'):
-            context += f"- 거주지역: {user_info.get('residence')}\n"
-        if user_info.get('favorite_food'):
-            context += f"- 좋아하는 음식: {user_info.get('favorite_food')}\n"
-        if user_info.get('memorable_place'):
-            context += f"- 추억의 장소: {user_info.get('memorable_place')}\n"
-        if user_info.get('favorite_song'):
-            context += f"- 좋아했던 노래/가수: {user_info.get('favorite_song')}\n"
-        if user_info.get('important_people'):
-            context += f"- 주변 중요 인물: {user_info.get('important_people')}\n"
-        context += "\n"
-        
-    # 2. memory_contents 테이블 키워드 매칭 검색 (RAG 검색 기능)
-    # 쿼리의 핵심 명사 단어를 추출하여 매칭해보는 간단한 검색 로직 구현
-    # memory_contents 데이터가 있다면 해당 결과를 참고용으로 제공
-    matched_memories = []
-    keywords = [word for word in query.split() if len(word) > 1]
-    
-    if keywords:
-        from database.db_config import fetch_all_dict
-        like_clauses = " OR ".join(["title LIKE %s OR description LIKE %s" for _ in keywords])
-        search_query = f"""
-            SELECT category, decade, title, description 
-            FROM memory_contents 
-            WHERE {like_clauses}
-            LIMIT 3
-        """
-        params = []
-        for kw in keywords:
-            params.extend([f"%{kw}%", f"%{kw}%"])
-            
-        try:
-            matched_memories = fetch_all_dict(search_query, tuple(params))
-        except Exception as e:
-            print(f"[RAG 검색 에러] {e}")
-            
-    if matched_memories:
-        context += "참고용 근현대 생활사/추억 정보 (회상 자극제):\n"
-        for idx, item in enumerate(matched_memories):
-            context += f"소재 {idx+1}. [{item.get('category', '일반')}] {item.get('title')}: {item.get('description')} ({item.get('decade', '연도 미상')})\n"
-        context += "\n"
-        
-    return context
-
